DATABASE_URL=postgresql+asyncpg://hes:hes@localhost:5432/hes
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TCP_INGRESS_HOST=0.0.0.0
TCP_INGRESS_PORT=8766
TCP_INGRESS_ENABLED=true
ONLINE_WINDOW_SECONDS=900

# DLMS صادر (السيرفر يتصل بالمقياس) — منفذ مختلف عن TCP_INGRESS_PORT (8766)
DLMS_TCP_PORT=8766
DLMS_CLIENT_ADDRESS=16
DLMS_SERVER_ADDRESS=1
# WRAPPER أو HDLC حسب الجهاز
DLMS_INTERFACE=WRAPPER
# NONE أو LOW
DLMS_AUTHENTICATION=NONE
DLMS_PASSWORD=
# OBIS إضافية للقراءة، مفصولة بفاصلة (اختياري)
# DLMS_EXTRA_READ_OBIS=1.0.1.8.0.255,1.0.2.8.0.255
